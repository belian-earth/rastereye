{
  "name": "rastereye",
  "displayName": "RasterEye",
  "description": "Quick GeoTIFF viewer with colormaps, false color composites, and basemap selection",
  "version": "0.1.0",
  "publisher": "belian-earth",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/belian-earth/rastereye.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "rastereye.geotiffViewer",
        "displayName": "RasterEye GeoTIFF Viewer",
        "selector": [
          {
            "filenamePattern": "*.tif"
          },
          {
            "filenamePattern": "*.tiff"
          },
          {
            "filenamePattern": "*.TIF"
          },
          {
            "filenamePattern": "*.TIFF"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "rastereye.open",
        "title": "Open in RasterEye"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "rastereye.open",
          "when": "resourceFilename =~ /\\.(tif|tiff)$/i",
          "group": "navigation@99"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "vsce:package": "vsce package --no-dependencies",
    "package": "npm run vsce:package"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.19.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@deck.gl/core": "^9.3.0",
    "@deck.gl/geo-layers": "^9.3.0",
    "@deck.gl/layers": "^9.3.0",
    "@deck.gl/mapbox": "^9.3.0",
    "@deck.gl/mesh-layers": "^9.3.0",
    "@developmentseed/deck.gl-geotiff": "^0.6.1",
    "@developmentseed/deck.gl-raster": "^0.6.1",
    "@developmentseed/morecantile": "^0.6.1",
    "@luma.gl/core": "^9.3.2",
    "@luma.gl/shadertools": "^9.3.2",
    "@luma.gl/webgl": "^9.3.2",
    "geotiff": "^3.0.5"
  }
}
