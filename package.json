{
  "name": "rastereye",
  "displayName": "RasterEye",
  "description": "Quick GeoTIFF viewer with colormaps, false color composites, and basemap selection",
  "version": "0.1.0",
  "publisher": "rastereye",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "rastereye.geotiffViewer",
        "displayName": "RasterEye GeoTIFF Viewer",
        "selector": [
          {
            "filenamePattern": "*.tif"
          },
          {
            "filenamePattern": "*.tiff"
          },
          {
            "filenamePattern": "*.geotiff"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@deck.gl/core": "^9.2.7",
    "@deck.gl/geo-layers": "^9.2.7",
    "@deck.gl/layers": "^9.2.7",
    "@deck.gl/mapbox": "^9.2.7",
    "@deck.gl/mesh-layers": "^9.2.7",
    "@developmentseed/deck.gl-geotiff": "^0.3.0",
    "@developmentseed/deck.gl-raster": "^0.3.0",
    "@luma.gl/core": "^9.2.6",
    "@luma.gl/webgl": "^9.2.6"
  }
}
